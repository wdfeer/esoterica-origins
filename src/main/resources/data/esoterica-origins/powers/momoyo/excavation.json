{
  "name": "Mine Blast",
  "description": "When toggled, mined blocks create a small explosion, destroying nearby blocks and erasing the item drop.",
  "type": "origins:multiple",
  "toggle": {
    "type": "origins:toggle",
    "key": {
      "key": "key.origins.secondary_active"
    },
    "active_by_default": false
  },
  "explode": {
    "type": "origins:action_on_block_break",
    "condition": {
      "type": "origins:power_active",
      "power": "esoterica-origins:momoyo/excavation_toggle"
    },
    "block_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:explosion"
        },
        {
          "type": "origins:execute_command",
          "command": "playsound minecraft:entity.generic.explode player @a ~ ~ ~ 0.7"
        },
        {
          "type": "origins:explode",
          "power": 1,
          "destruction_type": "break",
          "create_fire": false
        }
      ]
    },
    "only_when_harvested": false
  }
}