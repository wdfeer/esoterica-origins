{
  "name": "Mine Blast",
  "description": "When toggled, upon breaking a block, adjacent blocks are also destroyed.",
  "type": "origins:multiple",
  "toggle": {
    "type": "origins:toggle",
    "key": {
      "key": "key.origins.secondary_active"
    },
    "active_by_default": false
  },
  "explode": {
    "type": "origins:action_on_block_break",
    "condition": {
      "type": "origins:power_active",
      "power": "esoterica-origins:momoyo/excavation_toggle"
    },
    "block_action": {
      "type": "origins:and",
      "actions": [
        {
          "type": "origins:execute_command",
          "command": "particle minecraft:explosion"
        },
        {
          "type": "origins:execute_command",
          "command": "playsound minecraft:entity.generic.explode player @a ~ ~ ~ 0.5"
        },
        {
          "type": "origins:area_of_effect",
          "radius": 1,
          "shape": "star",
          "block_action": {
            "type": "origins:execute_command",
            "command": "setblock ~ ~ ~ air destroy"
          },
          "block_condition": {
            "type": "origins:hardness",
            "comparison": "!=",
            "compare_to": -1
          }
        }
      ]
    },
    "only_when_harvested": false
  }
}